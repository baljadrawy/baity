# ============================================================
# .env.local.example — "بيتي"
# انسخ هذا الملف إلى .env.local وأضف القيم الحقيقية
# هذا الملف في Git — لا تضع قيماً حقيقية هنا أبداً
# ============================================================

# ---- قاعدة البيانات (Supabase / PostgreSQL) ----
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/baity?schema=public"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/baity"

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ---- Auth / JWT ----
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# ---- التطبيق ----
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="بيتي"
NODE_ENV="development"

# ---- Telegram Bot ----
TELEGRAM_BOT_TOKEN="your-bot-token"
TELEGRAM_WEBHOOK_URL="https://your-domain.com/api/v1/telegram/webhook"

# ---- Redis (BullMQ) ----
REDIS_URL="redis://localhost:6379"

# ---- التخزين (Supabase Storage) ----
STORAGE_BUCKET_HOUSEHOLDS="households"
STORAGE_MAX_FILE_SIZE_MB="20"

# ---- Rate Limiting (Upstash) ----
UPSTASH_REDIS_REST_URL="https://YOUR_URL.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# ---- OCR (للضمانات) ----
OPENAI_API_KEY="sk-..."

# ---- Feature Flags ----
FEATURE_HOUSE_ECONOMY="true"
FEATURE_WARRANTY_OCR="true"
FEATURE_TELEGRAM="true"
FEATURE_CHARITY="false"
FEATURE_FAMILY_BANK="false"

# ---- Sentry (الأخطاء) ----
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# ---- Cron (مطلوب لتشغيل /api/v1/cron/* endpoints) ----
# أنشئه بـ: openssl rand -base64 32 | tr -d /+= | head -c 32
CRON_SECRET=""
